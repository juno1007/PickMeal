<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hankki.pickmeal.mapper.GameMapper">
    <insert id="insertGameRecord" parameterType="com.hankki.pickmeal.domain.Game">
        INSERT INTO game (user_id, food_id, gameType, playDate)
        VALUES (
        #{user_id},
        #{food_id},
        #{gameType},
        #{playDate}
        )
    </insert>
</mapper>