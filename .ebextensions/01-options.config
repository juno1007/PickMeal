option_settings:
  aws:elasticbeanstalk:application:environment:
    # Spring Profile
    SPRING_PROFILES_ACTIVE: prod

    # Server
    PORT: 8080
    SERVER_BASE_URL: https://your-domain.com

    # DB (실제 값은 EB 콘솔 > 환경 > 구성 > 소프트웨어에서 직접 입력)
    DB_URL: jdbc:mysql://your-rds-endpoint:3306/pickmeal?useSSL=true&serverTimezone=Asia/Seoul
    DB_USERNAME: pickmeal
    DB_PASSWORD: CHANGE_ME

    # AWS S3
    AWS_S3_BUCKET: pickmeal
    AWS_REGION: ap-northeast-2
    AWS_ACCESS_KEY: CHANGE_ME
    AWS_SECRET_KEY: CHANGE_ME

    # OAuth2 - Kakao
    KAKAO_CLIENT_ID: CHANGE_ME
    KAKAO_CLIENT_SECRET: CHANGE_ME

    # OAuth2 - Naver
    NAVER_CLIENT_ID: CHANGE_ME
    NAVER_CLIENT_SECRET: CHANGE_ME

    # OAuth2 - Google
    GOOGLE_CLIENT_ID: CHANGE_ME
    GOOGLE_CLIENT_SECRET: CHANGE_ME

    # Mail
    MAIL_USERNAME: CHANGE_ME
    MAIL_PASSWORD: CHANGE_ME

    # File Upload
    FILE_UPLOAD_DIR: /tmp/upload/

    # Redis (사용 시 주석 해제)
    # REDIS_HOST: your-redis-endpoint
    # REDIS_PORT: 6379
    # REDIS_PASSWORD: CHANGE_ME

  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

  aws:elasticbeanstalk:container:tomcat:jvmoptions:
    JVM Options: "-Dspring.profiles.active=prod"
